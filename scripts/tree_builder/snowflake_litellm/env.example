# Snowflake Custom Provider 설정 예제
# 
# 계정 정보는 litellm_config.yaml의 model_list에서 관리됩니다.

# ========================================
# litellm_config.yaml 설정 예제
# ========================================
# 
# model_list:
#   - model_name: snowflake/mistral-7b
#     litellm_params:
#       model: snowflake-cortex/mistral-7b
#     custom_config:
#       account_identifier: "WAHYQHF-OVB82728"
#       username: "JJKIM0807"
#       private_key_path: "/app/keys/snowflake_rsa_key.pem"
#
#   - model_name: snowflake/mistral-7b-dev
#     litellm_params:
#       model: snowflake-cortex/mistral-7b-dev
#     custom_config:
#       account_identifier: "AXWHLPO-HVB36952"
#       username: "JJKIM0807"
#       private_key_path: "/app/keys/snowflake_dev_rsa_key.pem"
#
#   # 무제한 계정 추가 가능
#   - model_name: snowflake/llama3-8b-prod
#     litellm_params:
#       model: snowflake-cortx/llama3-8b
#     custom_config:
#       account_identifier: "YOUR_PROD_ACCOUNT_ID"
#       username: "YOUR_PROD_USERNAME"
#       private_key_path: "/app/keys/your_prod_key.pem"

# ========================================
# Snowflake Provider 옵션 설정 (선택사항)
# ========================================

# JWT 토큰 만료 시간 (분, 기본값: 59)
SNOWFLAKE_JWT_EXPIRY_MINUTES=59

# API 요청 타임아웃 (초, 기본값: 30)
SNOWFLAKE_REQUEST_TIMEOUT=30

# 최대 재시도 횟수 (기본값: 3)
SNOWFLAKE_MAX_RETRIES=3

# 재시도 지연 시간 (초, 기본값: 1.0)
SNOWFLAKE_RETRY_DELAY=1.0

# ========================================
# 사용법:
# ========================================
# 1. litellm_config.yaml의 model_list에 위 예제와 같이 설정
# 2. 실제 계정 정보로 수정
# 3. LiteLLM 컨테이너 시작 (volume 마운트 확인)
# 4. 모델 사용
#
# 모델 사용 예제:
# - snowflake/mistral-7b (main 계정 사용)
# - snowflake/mistral-7b-dev (dev 계정 사용)
# - snowflake/llama3-8b-prod (prod 계정 사용)
# - snowflake/any-model-test (test 계정 사용)